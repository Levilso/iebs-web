---
// AdminNavMenu.astro - Navigation menu component
interface Props {
	items?: Array<{
		href: string;
		label: string;
		icon: string;
	}>;
}

const { items = [] } = Astro.props;

// Default items
const defaultItems = [
	{
		href: '/admin/',
		label: 'Dashboard',
		icon: 'M3 12l2-3m0 0l7-4 7 4M5 9v10a1 1 0 001 1h12a1 1 0 001-1V9m-9 4v4m0-11V5a1 1 0 011-1h2a1 1 0 011 1v2m0 0V5'
	},
	{
		href: '/admin/crearEvento',
		label: 'Crear Evento',
		icon: 'M12 4v16m8-8H4'
	},
	{
		href: '/admin/editar',
		label: 'Editar Eventos',
		icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z'
	},
	{
		href: '/eventos',
		label: 'Ver Eventos',
		icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z'
	}
];

const navItems = items.length > 0 ? items : defaultItems;
---

<nav class="flex-1 px-3 py-4 overflow-y-auto">
	<div class="space-y-2">
		{navItems.map((item) => (
			<a
				href={item.href}
				class="flex items-center px-4 py-2 rounded-lg hover:bg-gray-700 transition-colors duration-200"
			>
				<svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}></path>
				</svg>
				<span>{item.label}</span>
			</a>
		))}
	</div>
</nav>
