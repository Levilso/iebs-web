---
import type { CollectionEntry } from 'astro:content';


type Props = {
    event: CollectionEntry<'events'>;
};

const { event } = Astro.props;
const { title, description, date } = event.data;
---

<article class="
    bg-neutral-50 block
    w-100 p-6
    border rounded-md shadow-sm
    hover:bg-neutral-200 transition duration-300
">
  <div>
    <h2 class="font-extrabold text-2xl">{title}</h2>
    <time 
    class="text-sm"
    datetime={date.toISOString()}>
      <strong>Fecha:</strong> {date.toLocaleDateString(undefined, {dateStyle: 'medium', timeZone: 'UTC'})}
    </time>
    <p>{description}</p>
</div>
</article>

