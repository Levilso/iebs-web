---
// src/components/admin/Formularioevent.astro

// Recibimos los datos del event por props (si existen)
const { event } = Astro.props;

// Determinamos en qué modo estamos
const esEdicion = !!event;

// Formateamos la fecha para que el input type="date" la entienda (YYYY-MM-DD)
let fechaFormateada = "";
if (event?.date) {
  fechaFormateada = new Date(event.date).toISOString().split('T')[0];
}
---

<div class="max-w-2xl mx-auto bg-white p-8 rounded-lg shadow-md">
  <h2 class="text-2xl font-bold text-gray-800 mb-6">
    {esEdicion ? 'Editar Actividad' : 'Añadir Nueva Actividad'}
  </h2>

  <div id="mensaje-feedback" class="mb-4 font-medium rounded p-3 hidden"></div>

  <form id="form-event" 
    data-edicion={esEdicion.toString()} 
    class="space-y-5">
    
    {esEdicion && <input type="hidden" name="id" value={event.id} />}

    <div>
      <label class="block text-sm font-semibold text-gray-700">Título</label>
      <input type="text" name="title" value={event?.title || ''} required 
        class="mt-1 w-full p-2 border border-gray-300 rounded focus:ring-blue-500 focus:border-blue-500" />
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-semibold text-gray-700">Fecha</label>
        <input type="date" name="date" value={fechaFormateada} required 
          class="mt-1 w-full p-2 border border-gray-300 rounded focus:ring-blue-500 focus:border-blue-500" />
      </div>
      <div>
        <label class="block text-sm font-semibold text-gray-700">Precio (€)</label>
        <input type="number" step="0.01" name="price" value={event?.price || 0} required 
          class="mt-1 w-full p-2 border border-gray-300 rounded focus:ring-blue-500 focus:border-blue-500" />
      </div>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700">Ubicación</label>
      <input type="text" name="location" value={event?.location || 'Iglesia Evangélica Bautista de Sevilla'} required 
        class="mt-1 w-full p-2 border border-gray-300 rounded focus:ring-blue-500 focus:border-blue-500" />
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700">Descripción principal</label>
      <textarea name="description" rows="3" required 
        class="focus:ring-blue-500 focus:border-blue-500">{event?.description || ''}</textarea>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700">Información adicional</label>
      <textarea name="info" rows="2" 
        class="mt-1 w-full p-2 border border-gray-300 rounded focus:ring-blue-500 focus:border-blue-500">{event?.info || ''}</textarea>
    </div>

    <div class="flex items-center">
      <input type="checkbox" name="hidden" id="hidden" checked={event?.hidden} value="true"
        class="h-4 w-4 text-blue-600 border-gray-300 rounded focus:ring-blue-500" />
      <label for="hidden" class="ml-2 block text-sm text-gray-700">
        Ocultar event (Borrador)
      </label>
    </div>

    <button type="submit" id="btn-guardar" 
      class="w-full bg-blue-600 text-white font-bold py-2 px-4 rounded hover:bg-blue-700 transition duration-200">
      {esEdicion ? 'Actualizar event' : 'Publicar event'}
    </button>
  </form>
</div>

<script>
  import { actions } from 'astro:actions';

  const form = document.querySelector('#form-event') as HTMLFormElement;
  const feedback = document.querySelector('#mensaje-feedback') as HTMLDivElement;
  const btnGuardar = document.querySelector('#btn-guardar') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Leemos si el componente se renderizó en modo edición
    const esEdicion = form.dataset.edicion === 'true';
    
    btnGuardar.textContent = 'Procesando...';
    btnGuardar.disabled = true;
    feedback.classList.add('hidden');
    
    const formData = new FormData(form);

    // Llamamos a la acción correcta según el modo
    const accion = esEdicion ? actions.event.updateEventEntry : actions.event.createEventEntry;
    const { data, error } = await accion(formData);

    feedback.classList.remove('hidden');
    
    // if (error) {
    //   feedback.className = 'mb-4 font-medium rounded p-3 bg-red-100 text-red-700';
    //   feedback.textContent = `Error: ${error.message}`;
    // } else if (data?.success) {
    //   feedback.className = 'mb-4 font-medium rounded p-3 bg-green-100 text-green-700';
    //   feedback.textContent = data.message;
      
    //   // Si estamos creando, vaciamos el formulario al terminar
    //   if (!esEdicion) form.reset();
    // }

    btnGuardar.textContent = esEdicion ? 'Actualizar event' : 'Publicar event';
    btnGuardar.disabled = false;
  });
</script>