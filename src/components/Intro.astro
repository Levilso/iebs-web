---
const {background, h1} = Astro.props;
---

<div id="container"
    class={`
        -z-10
        w-full min-h-120 object-cover object-top
        pt-25
        bg-linear-to-r from-[#4cd1e9] to-[#0E889E]
        bg-cover bg-top
    `}
>
    <section id="hero">
		<h1 class="font-semibold text-white text-4xl p-5 text-center">
		{h1}
        </h1>
    </section>
</div>