---
import { db, EventEntry, desc } from "astro:db";

export const prerender = false;

const events = await db.select().from(EventEntry);
---
<div class="bg-white rounded-xl overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
                <th class="px-6 py-3 text-sm font-medium text-gray-500 uppercase tracking-wider">Título</th>
                <th class="px-6 py-3 text-sm font-medium text-gray-500 uppercase tracking-wider">Fecha</th>
                <th class="px-6 py-3 text-sm font-medium text-gray-500 uppercase tracking-wider">Ubicación</th>
                <th class="px-6 py-3 text-sm font-medium text-gray-500 uppercase tracking-wider text-center">Precio</th>
                <th class="px-6 py-3 text-sm font-medium text-gray-500 uppercase tracking-wider text-center">Estado</th>
                <th class="px-6 py-3 text-sm font-medium text-gray-500 uppercase tracking-wider text-center">Acciones</th>
            </tr>
        </thead>
        <tbody>
            {events.map((event) => (
                <tr class="border-b border-gray-200 hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
                    <td class="px-6 py-4 text-sm font-medium text-gray-900">{event.title}</td>
                    <td class="px-6 py-4 text-sm text-gray-500">{new Date(event.date).toLocaleDateString()}</td>
                    <td class="px-6 py-4 text-sm text-gray-500">{event.location}</td>                    
                    <td class="px-6 py-4 text-sm text-gray-500 text-center">{event.price.toFixed(2)}€</td>
                    <td class="p-4 text-center">
                        {event.hidden ? (
                            <span class="bg-yellow-100 text-yellow-700 text-xs px-2 py-1 rounded-full">Borrador</span>
                        ) : (
                            <span class="bg-green-100 text-green-700 text-xs px-2 py-1 rounded-full">Público</span>
                        )}
                    </td>
                    
                    <td class="p-4 flex justify-center gap-3">
                        <a href={`/admin/editar/${event.id}`} 
                            class="text-blue-600 hover:text-blue-800 font-medium text-sm transition-colors">
                            Editar
                        </a>
                    
                        <button 
                            data-id={event.id}
                            data-title={event.title}
                            class="btn-eliminar text-red-500 hover:text-red-700 font-medium text-sm transition-colors"
                        >
                            Eliminar
                        </button>
                    </td>
                </tr>))}
        </tbody>
    </table>

    {events.length === 0 && (
        <div class="p-6 text-center text-gray-500">
            No hay eventos registrados. Crea el primero para que aparezca aquí.
        </div>
    )}
</div>

<script>
    
</script>