---
// en esta página, se podrán crear nuevos eventos
import { db, EventEntry } from 'astro:db';
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';

export const prerender = false;

// renderizar la nueva lista de eventos en cada petición:
const events = await db.select().from(EventEntry);
---

<style>
    input, textarea {
        width: 100%;
        padding: 8px;
        margin-bottom: 10px;
        border: 1px solid #ccc;
        border-radius: 4px;
    }
</style>

<script>
    import { actions } from 'astro:actions';

    const form = document.getElementById('create-event-form') as HTMLFormElement;
    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
            console.log('Datos del formulario:', 
                'Título:', data.title,
                'Descripción:', data.description,
                'Información:', data.info,
                'Fecha:', data.date,
                'Ubicación:', data.location,
                'Precio:', data.price,
                'Oculto:', data.hidden
            );
            const result = await actions.event.createEventEntry(formData);

            // Éxito al crear el evento
            alert('Evento creado exitosamente');
            form.reset();

            // Recargar la página para mostrar el nuevo evento
            window.location.reload(); 

        } catch (error) {
            console.error('Error al crear el evento:', error);
            alert('Hubo un error al crear el evento. Por favor, inténtalo de nuevo.');
        }
    });
</script>

<BaseLayout pageTitle="Admin" description="Panel de administración para crear nuevos eventos y gestionar los existentes.">

    <h1 class="font-semibold text-black text-4xl p-5 text-center">
    Crear nuevo evento</h1>

    <form method="POST"
    class="grid grid-cols-1 justify-center mx-50"
    id="create-event-form"
    >

        <label for="title">Título del evento:</label>
        <input type="text" name="title" required>

        <label for="description">Descripción:</label>
        <textarea name="description" required></textarea>

        <label for="info">Información:</label>
        <textarea name="info" required></textarea>

        <label for="date">Fecha:</label>
        <input type="date" name="date" required>

        <label for="location">Ubicación:</label>
        <input type="text" name="location" required>

        <label for="price">Precio:</label>
        <input type="number" name="price" required>

        <label for="hidden">Ocultar evento:</label>
        <input type="checkbox" name="hidden">

        <button type="submit" 
        class="w-auto rounded-md px-4 py-2 bg-blue-400 text-white hover:bg-blue-500 transition-colors duration-300">
            Crear Evento</button>

    </form>

    <br>
    <section id="container"
		class="mx-20 py-5 h-auto">

        <h2 class="font-semibold text-black text-3xl py-5 mx-12 text-start">
        Eventos existentes:</h2>
		
        <div class="inline-flex flex-row flex-wrap gap-7 mx-12">
			{events.map((evento) => <EventCard evento={
				{title: evento.title, description: evento.description, date: evento.date}} />)}
		</div>

	</section>

</BaseLayout>