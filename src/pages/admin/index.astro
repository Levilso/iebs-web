---
export const prerender = false;

import EventGallery from "../../components/EventGallery.astro"
import EventTable from "../../components/EventTable.astro"

import AdminLayout from "../../layouts/AdminLayout.astro"

import { db, EventEntry, desc } from "astro:db";
const nextEvents = await db.select().from(EventEntry).orderBy(desc(EventEntry.date));

---
<AdminLayout pageTitle="Panel de Administración">

    <section class="bg-white rounded-xl shadow-lg">
        <div class="px-5 py-10 mb-4 flex justify-between items-start">
            <h1 class="text-3xl font-bold text-gray-800">Agenda de Actividades</h1>

            <a href="/admin/crearEvento" 
            class="rounded-lg px-4 py-2 flex flex-nowrap items-center
            bg-blue-600 text-white font-semibold shadow-
            hover:bg-blue-700 hover:font-bold transition-colors">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M12 4v16m8-8H4"></path>
                </svg>    
                Crear evento
            </a>
        </div>

        <div class="p-4">
            <EventTable />
        </div>
    </section>

    <EventGallery />


</AdminLayout>